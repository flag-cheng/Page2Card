# Copy to .env to override defaults. All values are optional.

# SQLite database location (default: data/page2card.db under the project root).
# PAGE2CARD_DB_PATH=data/page2card.db

# HTTP fetch limits.
# PAGE2CARD_CONNECT_TIMEOUT=5.0
# PAGE2CARD_READ_TIMEOUT=10.0
# PAGE2CARD_MAX_RESPONSE_BYTES=2097152
# PAGE2CARD_MAX_CONTENT_CHARS=20000

# User-Agent sent with outbound requests.
# PAGE2CARD_USER_AGENT=...

# --- Reserved for the Codex issue (AI summary + style card). Not used by the
#     starter. See PAGE2CARD_ISSUE.md. ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.5
# OPENAI_IMAGE_MODEL=gpt-image-1
